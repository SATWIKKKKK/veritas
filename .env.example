# Frontend Firebase configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Optional. Leave blank when the OTP backend is deployed in the same Vercel project.
VITE_API_BASE_URL=

# Server-side OTP backend configuration
FIREBASE_PROJECT_ID=
OTP_SESSION_SECRET=

# Local-only. Set to true to surface the OTP in development instead of sending email.
OTP_DEV_MODE=false

# Production email delivery via Resend
RESEND_API_KEY=
OTP_FROM_EMAIL=
OTP_EMAIL_SUBJECT=Your Veritas verification code
